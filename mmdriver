<!DOCTYPE html><html lang="pl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>MM Driver – Transport VIP Zielona Góra</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box}
body{margin:0;font-family:Montserrat,Arial;background:#0c0c0d;color:#fff}header{position:fixed;top:0;width:100%;background:rgba(0,0,0,0.9);backdrop-filter:blur(6px);z-index:10} nav{max-width:1200px;margin:auto;display:flex;justify-content:space-between;align-items:center;padding:18px} nav a{color:#d4af37;text-decoration:none;margin-left:20px;font-weight:600} .logo{font-weight:700;font-size:20px;color:#fff}

.hero{height:100vh;background:url("https://images.unsplash.com/photo-1617814076668-5d28d9d88c42") center/cover no-repeat;display:flex;align-items:center} .hero-content{max-width:1200px;margin:auto;padding:40px} .hero h1{font-size:52px;margin-bottom:10px} .hero h2{font-weight:400;margin-bottom:25px} .btn{background:#d4af37;color:#000;border:none;padding:14px 26px;border-radius:6px;font-weight:700;cursor:pointer}

section{max-width:1200px;margin:auto;padding:100px 20px}

.services{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:25px} .service{background:#17171a;padding:30px;border-radius:12px;text-align:center}

.airports{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;margin-top:30px} .airport{background:#17171a;padding:20px;border-radius:10px;text-align:center}

.fleet{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:25px} .fleet-card{background:#17171a;border-radius:12px;overflow:hidden} .fleet-card img{width:100%;height:220px;object-fit:cover} .fleet-card .info{padding:20px}

.price-table{width:100%;border-collapse:collapse;margin-top:20px} .price-table th,.price-table td{padding:12px;border-bottom:1px solid #333;text-align:left}

.hourly{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:25px;margin-top:30px} .hour-card{background:#17171a;padding:25px;border-radius:10px} .hour-card h3{color:#d4af37}

.booking{display:grid;grid-template-columns:1fr 1fr;gap:30px} .form input,.form select{width:100%;padding:12px;border-radius:6px;border:none;margin-top:8px;margin-bottom:14px}

.price-box{background:#17171a;padding:25px;border-radius:10px;font-size:22px;color:#d4af37}

.map{margin-top:40px;border-radius:10px;overflow:hidden}

.whatsapp{ position:fixed; bottom:25px; right:25px; background:#25D366; color:white; padding:16px 20px; border-radius:50px; font-weight:600; text-decoration:none; box-shadow:0 4px 10px rgba(0,0,0,0.4) }

footer{background:#000;text-align:center;padding:30px;margin-top:60px}

@media(max-width:900px){ .hero h1{font-size:38px} .booking{grid-template-columns:1fr} } </style>

</head>
<body><header>
<nav>
<div class="logo">MM DRIVER</div>
<div>
<a href="#services">Usługi</a>
<a href="#airports">Lotniska</a>
<a href="#fleet">Flota</a>
<a href="#pricing">Transfery</a>
<a href="#hourly">Na godziny</a>
<a href="#booking">Rezerwacja</a>
</div>
</nav>
</header><div class="hero">
<div class="hero-content">
<h1>MM DRIVER</h1>
<h2>Profesjonalny Kierowca VIP – Zielona Góra</h2>
<p>Transfery lotniskowe • Wynajem auta z kierowcą • Transport VIP</p>
<button class="btn" onclick="document.getElementById('booking').scrollIntoView()">Zarezerwuj przejazd</button>
</div>
</div><section id="services">
<h2>Usługi</h2>
<div class="services">
<div class="service">
<h3>Transport VIP</h3>
<p>Luksusowe przejazdy prywatne i biznesowe.</p>
</div>
<div class="service">
<h3>Transfery lotniskowe</h3>
<p>Komfortowe transfery z Zielonej Góry na lotniska.</p>
</div>
<div class="service">
<h3>Wynajem auta z kierowcą</h3>
<p>Możliwość wynajęcia samochodu z kierowcą na godziny.</p>
</div>
</div>
</section><section id="airports">
<h2>Transfery na lotniska</h2>
<p>Obsługujemy najważniejsze lotniska w regionie:</p><div class="airports">
<div class="airport">
<h3>Babimost</h3>
<p>Lotnisko Zielona Góra</p>
</div><div class="airport">
<h3>Poznań</h3>
<p>Port lotniczy Ławica</p>
</div><div class="airport">
<h3>Wrocław</h3>
<p>Lotnisko Strachowice</p>
</div><div class="airport">
<h3>Berlin</h3>
<p>Berlin Brandenburg Airport</p>
</div>
</div>
</section><section id="fleet">
<h2>Nasza Flota</h2>
<div class="fleet"><div class="fleet-card">
<img src="https://images.unsplash.com/photo-1618843479313-40f8afb4b4d8" alt="Mercedes">
<div class="info">
<h3>Mercedes CLA</h3>
<p>VIP transport</p>
<ul>
<li>komfortowa podróż</li>
<li>transfery lotniskowe</li>
<li>obsługa biznesowa</li>
</ul>
</div>
</div><div class="fleet-card">
<img src="https://images.unsplash.com/photo-1605559424843-9e4c228bf1c2" alt="Toyota">
<div class="info">
<h3>Toyota Corolla</h3>
<p>Komfortowy transport</p>
<ul>
<li>do 4 pasażerów</li>
<li>przejazdy miejskie</li>
<li>transfery lotniskowe</li>
</ul>
</div>
</div></div>
</section><section id="pricing">
<h2>Średnie ceny transferów</h2>
<table class="price-table">
<tr><th>Trasa</th><th>Toyota</th><th>Mercedes</th></tr>
<tr><td>Zielona Góra → Babimost</td><td>130 zł</td><td>180 zł</td></tr>
<tr><td>Zielona Góra → Poznań</td><td>380 zł</td><td>520 zł</td></tr>
<tr><td>Zielona Góra → Wrocław</td><td>550 zł</td><td>720 zł</td></tr>
<tr><td>Zielona Góra → Berlin</td><td>800 zł</td><td>990 zł</td></tr>
</table>
</section><section id="hourly">
<h2>Wynajem auta z kierowcą na godziny</h2>
<div class="hourly"><div class="hour-card">
<h3>Toyota Corolla</h3>
<p><strong>150 zł / godzina</strong></p>
<ul>
<li>transport miejski</li>
<li>spotkania biznesowe</li>
<li>transfery lotniskowe</li>
<li>minimum wynajmu 2 godziny</li>
</ul>
</div><div class="hour-card">
<h3>Mercedes CLA VIP</h3>
<p><strong>250 zł / godzina</strong></p>
<ul>
<li>transport VIP</li>
<li>obsługa eventów</li>
<li>transport biznesowy</li>
<li>minimum wynajmu 2 godziny</li>
</ul>
</div></div>
</section><section id="booking">
<h2>Kalkulator ceny i rezerwacja</h2>
<div class="booking"><div class="form">
<label>Auto</label>
<select id="car">
<option value="toyota">Toyota Corolla</option>
<option value="mercedes">Mercedes CLA</option>
</select><label>Trasa</label> <select id="route">

<option value="babimost">Zielona Góra → Babimost</option>
<option value="poznan">Zielona Góra → Poznań</option>
<option value="wroclaw">Zielona Góra → Wrocław</option>
<option value="berlin">Zielona Góra → Berlin</option>
</select><label>Adres odbioru</label> <input placeholder="np. ul. Bohaterów Westerplatte 10">

<label>Imię i nazwisko</label> <input placeholder="Jan Kowalski">

<label>Telefon</label> <input placeholder="+48 000 000 000">

<label>Data przejazdu</label> <input type="date">

<label>Godzina</label> <input type="time">

<button class="btn" onclick="alert('Rezerwacja wysłana')">Wyślij rezerwację</button>

</div><div>
<div class="price-box" id="price">Cena: wybierz trasę</div><div class="map">
<iframe
width="100%"
height="300"
frameborder="0"
style="border:0"
referrerpolicy="no-referrer-when-downgrade"
src="https://www.google.com/maps?q=Zielona+Gora&output=embed"
allowfullscreen>
</iframe>
</div>
</div></div>
</section><footer>
<p>MM Driver • Zielona Góra • Transfery lotniskowe • Wynajem auta z kierowcą</p>
</footer><a class="whatsapp" href="https://wa.me/48123456789" target="_blank">WhatsApp</a>

<script>
const prices={
 babimost:{toyota:130,mercedes:180},
 poznan:{toyota:380,mercedes:520},
 wroclaw:{toyota:550,mercedes:720},
 berlin:{toyota:800,mercedes:990}
}

function updatePrice(){
const car=document.getElementById('car').value
const route=document.getElementById('route').value
const price=prices[route][car]

let carName = car==='toyota' ? 'Toyota Corolla' : 'Mercedes CLA'

 document.getElementById('price').innerHTML =
 `Cena przejazdu:<br><b>${price} zł</b><br><br>Wybrane auto: ${carName}`
}

document.getElementById('car').addEventListener('change',updatePrice)
document.getElementById('route').addEventListener('change',updatePrice)
</script></body>
</html>
